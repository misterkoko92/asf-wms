msgstr "A button lets you receive all pending lines."

#: templates/scan/faq.html:279 templates/scan/receipts_view.html:9
msgid "Vue réception"
msgstr "Receiving view"

#: templates/scan/faq.html:281
msgid "Filtre rapide : Palette, Association ou Tout."
msgstr "Quick filter: Pallet, Association, or All."

#: templates/scan/faq.html:282
msgid ""
"Colonnes : date, nom, quantité palettes/colis, hors format, transporteur."
msgstr "Columns: date, name, pallet/parcel quantities, out-of-format, carrier."

#: templates/scan/faq.html:287
msgid "Imports (admin)"
msgstr "Imports (admin)"

#: templates/scan/faq.html:289
msgid "Ajout unitaire ou import CSV/XLS/XLSX par bloc."
msgstr "Single add or batch CSV/XLS/XLSX import."

#: templates/scan/faq.html:291
msgid "Templates disponibles + export complet de chaque table."
msgstr "Templates available + full export for each table."

#: templates/scan/faq.html:292
msgid "Produit: match par SKU sinon Nom+Marque, confirmation avant update."
msgstr ""
"Product: match on SKU, otherwise Name+Brand, with confirmation before update."

#: templates/scan/faq.html:293
msgid "Si SKU déjà utilisé et création forcée: SKU auto-généré."
msgstr "If the SKU is already used and creation is forced: auto-generated SKU."

#: templates/scan/faq.html:294
msgid "Quantité initiale applique un mouvement de stock (emplacement requis)."
msgstr "Initial quantity applies a stock movement (location required)."

#: templates/scan/faq.html:295
msgid "Emplacements: entrepôt/rack/étagère/bac requis, rack color optionnel."
msgstr "Locations: warehouse/rack/shelf/bin required, rack color optional."

#: templates/scan/faq.html:296
msgid "Catégories: chemin possible (L1 > L2 > L3)."
msgstr "Categories: path supported (L1 > L2 > L3)."

