#: templates/scan/faq.html:210
msgid "Documents & étiquettes"
msgstr "Documents & labels"

#: templates/scan/faq.html:212
msgid ""
"Bon d'expédition, listes de colisage et attestation sont générés par "
"expédition."
msgstr ""
"Shipment notes, packing lists, and certificates are generated per shipment."

#: templates/scan/faq.html:213
msgid "Étiquettes colis générées par carton (impression en masse possible)."
msgstr "Parcel labels are generated per parcel (bulk printing available)."

#: templates/scan/faq.html:214
msgid ""
"Le QR code expédition apparait sur l'étiquette et ouvre le suivi public."
msgstr "The shipment QR code appears on the label and opens public tracking."

#: templates/scan/faq.html:215
msgid "Documents additionnels uploadables (PDF, JPG, PNG, XLSX, DOCX)."
msgstr "Additional documents can be uploaded (PDF, JPG, PNG, XLSX, DOCX)."

#: templates/scan/faq.html:220
