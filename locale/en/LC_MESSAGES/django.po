msgid ""
"Mapping des colonnes avec champs requis: <strong>nom + quantité</strong>."
msgstr "Map columns with required fields: <strong>name + quantity</strong>."

#: templates/scan/faq.html:246
msgid ""
"Récap: choix du match produit, édition des champs, validation ligne par "
