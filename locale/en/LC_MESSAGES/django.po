msgstr "Order view (associations)"

#: templates/scan/faq.html:222
msgid "Liste des demandes associations avec statut de revue."
msgstr "Lists association requests with their review status."

#: templates/scan/faq.html:223
msgid "Changer le statut et informer le contact (refus / à modifier)."
msgstr "Change the status and notify the contact (rejected / needs changes)."

#: templates/scan/faq.html:224
msgid "Si approuvé, création d'expédition en un clic."
msgstr "If approved, create a shipment in one click."

#: templates/scan/faq.html:225
