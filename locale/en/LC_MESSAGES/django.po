msgstr "Recap: choose the product match, edit fields, validate line by line."

#: templates/scan/faq.html:247
msgid "Match auto sur <strong>Nom + Marque</strong> (liste modifiable)."
msgstr "Automatic match on <strong>Name + Brand</strong> (editable list)."

#: templates/scan/faq.html:248
msgid ""
"Si produit existant: champs produit en lecture seule, seules quantité / "
"emplacement changent."
msgstr ""
"If the product already exists: product fields stay read-only, only quantity "
