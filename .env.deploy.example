# Local prod-like profile for `manage.py check --deploy`
# Usage:
#   set -a && source .env.deploy.example && set +a
#   python manage.py check --deploy --fail-level WARNING

DJANGO_SECRET_KEY=replace-with-a-strong-random-secret-key-at-least-50-characters-long
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=example.com,www.example.com
SITE_BASE_URL=https://example.com

SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true
USE_PROXY_SSL_HEADER=true
TRUSTED_PROXY_IPS=127.0.0.1

DOCUMENT_SCAN_BACKEND=clamav
DOCUMENT_SCAN_CLAMAV_COMMAND=clamscan
DOCUMENT_SCAN_TIMEOUT_SECONDS=30
DOCUMENT_SCAN_QUEUE_PROCESSING_TIMEOUT_SECONDS=900
